{
  "expo": {
    "name": "Go Bananas",
    "slug": "gobananas",
    "owner": "harnischllc",
    "scheme": "gobananas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5c518"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harnischllc.gobananas",
      "buildNumber": "14",
      "infoPlist": {
        "NSCameraUsageDescription": "Go Bananas uses your camera to check banana ripeness.",
        "NSPhotoLibraryUsageDescription": "Go Bananas can check ripeness of bananas in your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.harnischllc.gobananas",
      "versionCode": 14,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5c518"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Go Bananas can check ripeness of bananas in your photo library.",
          "cameraPermission": "Go Bananas uses your camera to check banana ripeness.",
          "microphonePermission": false
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12cbfe1c-51f6-4ff3-996f-3ecb1a6d6de8"
      }
    }
  }
}

metadata:
  name: "Repo-wide Cursor Rules"
  version: "1.0.0"
  maintainer: "Eric Harnisch"
  description: "Standard behavior, response format, and guardrails for all work done by Cursor in this repository."

deployment_context:
  platform: "render.com"
  notes:
    - "Assume cold starts and execution timeouts."
    - "Assume ephemeral filesystem; do not rely on local persistence."
    - "Prefer environment variables; never commit secrets."
    - "Log enough for production debugging (level INFO by default)."

principles:
  - "ALWAYS CHECK EXISTING CODE FIRST."
  - "Simplicity over cleverness; smallest change that works."
  - "Memory discipline: re-read relevant files before coding."
  - "One change at a time; test before moving on."
  - "Respect current architecture and naming."

response_format:
  required_sections:
    - "OBJECTIVE"
    - "FILES TO MODIFY"
    - "IMPLEMENTATION"
    - "DOS"
    - "DON'TS"
    - "TESTING CHECKLIST"
    - "REMINDERS"
  rules:
    - "Every Cursor reply MUST include all required sections in the order above."
    - "Use exact file paths and exact function names."
    - "Show real code (no pseudocode). Include imports."
    - "Assume technical competence; do not explain basics."
    - "Be direct and technical; no filler language."

code_standards:
  file_organization:
    - "Keep related functions together."
    - "Avoid new files unless strictly necessary; justify when created."
    - "Use clear, descriptive names; avoid abbreviations."
  functions:
    - "Single responsibility; target <=50 lines when feasible."
    - "Prefer async/await over promise chains."
    - "Explain WHY in comments, not WHAT."
    - "Explicit error handling; no swallow-and-log-only."
  api_ops:
    - "Batch operations when possible."
    - "Retry transient failures with backoff."
    - "Graceful handling of rate limits and timeouts."
    - "Structured logging around external calls."
  env_vars:
    - "Never hardcode credentials."
    - "Validate required env vars at startup with clear errors."
    - "Document required env vars in code comments near usage."

don_ts:
  over_engineering:
    - "No classes when plain functions suffice."
    - "No caching without measured need."
    - "No middleware unless used ≥3 places."
    - "No TypeScript migration unless explicitly requested."
  duplication:
    - "Search for utilities before adding new ones."
    - "Reuse existing API patterns."
    - "Do not copy-paste between files."
  safety:
    - "Do not break existing behavior; test first."
    - "Keep backward compatibility unless told otherwise."
    - "No broad refactors without a specific reason tied to a task."
  deployment_awareness:
    - "Consider cold starts/timeouts."
    - "Assume ephemeral FS."
    - "Emit logs sufficient for prod debugging."

testing_requirements:
  before_commit:
    - "Run the app and verify baseline behavior."
    - "Check logs for errors/warnings."
    - "Test in production-like settings (Render assumptions)."
    - "Cover error paths, rate limits, and timeouts."
    - "Confirm no regression in existing functionality."
  scenarios_always:
    - "Happy path."
    - "Error/edge cases."
    - "Rate limits and transient failures."
    - "Network failures/timeouts."
    - "Validation/malformed inputs."

communication_style:
  - "Direct, technical, specific."
  - "No validation phrases; no fluff."
  - "Exact file paths and function names."
  - "Show code with imports."
  - "Provide context only for non-obvious decisions."

uncertainty_protocol:
  - "If unsure about existing functionality: search codebase first, then ask."
  - "If unsure about behavior: read relevant files fully and describe what exists."
  - "Default to NO on adding new surface area unless explicitly requested."

# -----------------------------
# File-type & path-specific rules
# -----------------------------
rules:
  - match: "**/*.py"
    instructions: |
      - Use type hints.
      - Google-style docstrings with Args/Returns/Raises.
      - Prefer dataclasses for simple data carriers.
      - Centralize constants and config.
      - Use logging.getLogger(__name__) and structured log messages.

  - match: "**/*.ts"
    instructions: |
      - Strict types; no 'any' unless justified.
      - Keep modules small and cohesive.
      - Never export unused symbols.
      - Align with existing tsconfig and lint rules.

  - match: "**/*.js"
    instructions: |
      - Prefer ES modules and async/await.
      - Keep functions pure where possible.
      - Reuse existing helper utilities.

  - match: "**/*.md"
    instructions: |
      - H2 for top-level, H3 for subsections.
      - Hard-wrap at ~100 chars when editing prose.
      - Include tangible examples/snippets over theory.

  - match: "README.md"
    instructions: |
      - Ensure sections: Overview, Setup, Env Vars, Run, Test, Deploy (Render), Troubleshooting, License.
      - Include a minimal end-to-end run example.

  - match: "**/*.env.example"
    instructions: |
      - Include all required variables with comments.
      - No real secrets; placeholder values only.

# -----------------------------
# Enforced reply template (strict)
# -----------------------------
reply_template: |
  **OBJECTIVE:** <one sentence>
  **FILES TO MODIFY:**
  - <path> — <what changes>
  - <path> — <what changes>

  **IMPLEMENTATION:**
  <step-by-step with code blocks and imports>

  **DOS:**
  - <specific action + reason>
  - <specific action + reason>

  **DON'TS:**
  - <don't X because Y>
  - <don't Z because present in <path>>

  **TESTING CHECKLIST:**
  - [ ] <test>
  - [ ] <test>
  - [ ] <regression check>

  **REMINDERS:**
  - <existing code to re-check>
  - <common pitfall to avoid>

# -----------------------------
# Guardrails / constraints
# -----------------------------
constraints:
  - "No secrets in code or commits."
  - "No dependency additions without justification and impact notes."
  - "No framework changes or language migrations without explicit request."
  - "If creating files, explain why existing files cannot host the change."
  - "Keep diffs minimal and readable."

# -----------------------------
# Context block (for typical stacks)
# -----------------------------
context:
  languages: ["python", "typescript", "javascript", "markdown"]
  services:
    - name: "Render"
      use_cases:
        - "Web services with cold starts"
        - "Background workers with timeouts"
  repository_goal: "Keep code simple, reusable, and deployable to Render with clear logging and minimal surface area."

# -----------------------------
# Examples (for few-shot guidance)
# -----------------------------
examples:
  - user: "Add a new endpoint to fetch banana ripeness predictions"
    assistant: |
      **OBJECTIVE:** Add GET /api/bananas/:id/ripeness with existing service.
      **FILES TO MODIFY:**
      - src/routes/bananas.ts — add route handler using ripenessService.getPrediction
      - src/services/ripenessService.ts — reuse getPrediction; no new functions
      **IMPLEMENTATION:**
      1) In src/routes/bananas.ts:
      ```ts
      import { Router } from "express";
      import { getPrediction } from "../services/ripenessService";
      const router = Router();

      router.get("/api/bananas/:id/ripeness", async (req, res) => {
        try {
          const result = await getPrediction(req.params.id);
          return res.status(200).json(result);
        } catch (err) {
          req.log?.error({ err }, "ripeness endpoint failed");
          return res.status(500).json({ error: "internal_error" });
        }
      });

      export default router;
      ```
      2) Do not add new files; function already exists.
      **DOS:**
      - Reuse getPrediction to avoid duplication.
      - Add structured error logging for prod debugging.
      **DON'TS:**
      - Don't introduce a new service; it already exists in src/services/ripenessService.ts.
      - Don't change routing prefix; keep /api for backward compatibility.
      **TESTING CHECKLIST:**
      - [ ] GET /api/bananas/123/ripeness returns 200 and JSON
      - [ ] Simulate service error returns 500
      - [ ] Existing bananas routes unaffected
      **REMINDERS:**
      - Check rate limiting middleware order.
      - Validate env var BANANA_API_KEY at startup.


